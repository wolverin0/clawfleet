# Runtime env for theorchestra. Copy to .env.local and fill in secrets.
# .env.local is gitignored; DO NOT commit it.

# Telegram A-7 — escalations push notifications
# Create bot via @BotFather, get chat_id via @userinfobot or getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: forum-topic thread_id for group with topics enabled
TELEGRAM_MESSAGE_THREAD_ID=

# Auth
# THEORCHESTRA_TOKEN_FILE=G:/_OneDrive/OneDrive/Desktop/Py Apps/wezbridge/vault/_auth/token.json
# THEORCHESTRA_NO_AUTH=1  # dev only — disables bearer-token auth

# Omniclaude
# THEORCHESTRA_OMNICLAUDE=1
# THEORCHESTRA_OMNICLAUDE_CWD=G:/_OneDrive/OneDrive/Desktop/Py Apps/wezbridge/vault/_omniclaude
# THEORCHESTRA_NO_KILL_ON_SHUTDOWN=1  # recommended — avoids WezTerm kill cascade

# Dashboard
# THEORCHESTRA_PORT=4300
# THEORCHESTRA_NO_DASHBOARD_SNAPSHOT=1  # skip agent-browser Chrome launch
